{
    "name": "salvatorecervone/slowquerylog",
    "description": "In develop",
    "keywords": [
        "Salvatore",
        "laravel",
        "slowquerylog"
    ],
    "homepage": "https://github.com/salvatorecervone/slowquerylog",
    "license": "MIT",
    "authors": [
        {
            "name": "Salvatore",
            "email": "salvatore999@virgilio.it",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1.1||^7.10.0",
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.22.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "salvatorecervone\\Slowquerylog\\": "src/",
            "salvatorecervone\\Slowquerylog\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "salvatorecervone\\Slowquerylog\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "salvatorecervone\\Slowquerylog\\SlowquerylogServiceProvider"
            ],
            "aliases": {
                "Slowquerylog": "salvatorecervone\\Slowquerylog\\Facades\\Slowquerylog"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}